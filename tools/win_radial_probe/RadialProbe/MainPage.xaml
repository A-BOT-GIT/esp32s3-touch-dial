<Page
    x:Class="RadialProbe.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="ESP32 Radial Controller Probe"
                   FontSize="24" FontWeight="Bold"
                   Margin="0,0,0,8" />

        <!-- UWP: no Spacing, use Margin on children instead -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Status:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusText"
                       Text="Connecting to RadialController..."
                       Foreground="Gray" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock x:Name="RotationText"
                           Text="Rotation: 0.00"
                           FontSize="14" Margin="0,0,12,0"/>
                <TextBlock x:Name="ButtonText"
                           Text="Clicks: 0"
                           FontSize="14"/>
            </StackPanel>
            <TextBlock x:Name="MenuText"
                       Text="Menu: —"
                       FontSize="12" Foreground="DimGray"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Clear" Click="OnClearClicked" Width="80" Margin="0,0,8,0"/>
            <Button Content="Copy" Click="OnCopyClicked" Width="80"/>
        </StackPanel>

        <TextBlock Grid.Row="4"
                   Text="Events (newest first)"
                   FontWeight="SemiBold" Margin="0,0,0,4"/>

        <ListView Grid.Row="5"
                  x:Name="EventList"
                  FontFamily="Consolas"
                  FontSize="12"
                  SelectionMode="None"/>
    </Grid>
</Page>
